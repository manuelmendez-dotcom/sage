# Whitelist approach: ignore everything, only allow the disaster-recovery
# minimum — the two live production prompts + project context + memory.

# Ignore everything by default
*

# Allow .gitignore itself
!.gitignore

# Allow the project context file
!CLAUDE.md

# Allow the Versions directory, but ONLY the production subfolder contents.
# V3.0, V3.1 staging, and other historical prompts live locally only.
!Versions/
Versions/*
!Versions/production/
!Versions/production/sage_v3.1_main_production.md
!Versions/production/Datifyer_v3.1_production.md

# Allow the memory directory — every .md inside.
!memory/
!memory/*.md

# Explicit exclusions for tooling (redundant with * but kept for clarity)
.DS_Store
.claude/
