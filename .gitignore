# Whitelist approach: ignore everything by default, allow only the
# disaster-recovery essentials — live prompts, project context, supporting
# reference, memory.

# Ignore everything by default
*

# Allow .gitignore itself
!.gitignore

# Allow the project context file
!CLAUDE.md

# Allow live production prompts
!prompts/
!prompts/*.md

# Allow supporting reference (overview, changelog, skill, regression sessions)
!reference/
!reference/*.md

# Allow Claude Code auto-memory
!memory/
!memory/*.md

# Tooling exclusions (redundant with * but kept explicit)
.DS_Store
.claude/
