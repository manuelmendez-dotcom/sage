      "width": 800,
      "height": 45,
      "text": "Guardrails",
      "fontSize": 36,
      "fontFamily": 1,
      "textAlign": "left",
      "baseline": 36,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
